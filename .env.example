# Flask Configuration
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Authentication (generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# LLM Configuration (OpenAI-compatible API — vLLM, Ollama, or any OpenAI-compatible endpoint)
LLM_BASE_URL=http://your-llm-server:port/v1
LLM_MODEL=your-model-name
LLM_API_KEY=your-api-key-if-needed

# Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
MAX_CONTENT_LENGTH=16777216
